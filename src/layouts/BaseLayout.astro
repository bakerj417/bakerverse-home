---
import '@/styles/global.css';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import SEO from '@/components/ui/SEO.astro';
import { ViewTransitions } from 'astro:transitions';
import { foucGuardScript, initialThemeStyle } from '@/lib/theme/ssr';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  bodyClass?: string;
}

const {
  title,
  description,
  image,
  noindex = false,
  bodyClass = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />

    <!--
      FOUC guard: runs synchronously before first paint, reads
      localStorage('bakerverse.theme'), and stamps data-theme on <html>.
      Must be the FIRST script in <head> — before any stylesheet.
    -->
    <script set:html={foucGuardScript()} />

    <!--
      Server-rendered theme tokens. The client-side applyTheme() call will
      replace this block on hydration if the user's stored theme differs.
      The id lets applyTheme() find and reuse the element instead of
      appending a new one.
    -->
    <style id="bakerverse-theme" set:html={initialThemeStyle()} />

    <SEO
      title={title}
      description={description}
      image={image}
      noindex={noindex}
    />
    <ViewTransitions />
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Navbar />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!--
      Re-apply the stored theme after every ViewTransition swap.
      astro:after-swap fires once the new DOM is in place but before the
      browser paints — the right moment to inject the <style> block so there
      is no flash between route changes.

      We do NOT import from the theme module here (Astro client scripts run in
      a separate module scope), so we replicate the minimal logic inline.
    -->
    <script>
      import { initStore, getThemeId } from '@/lib/theme/store';
      import { applyTheme } from '@/lib/theme/apply';

      function reapply(): void {
        initStore();
        applyTheme(getThemeId());
      }

      // Fire once on initial page load to hydrate from localStorage
      reapply();

      // Fire after every ViewTransition so the new page gets the right theme
      document.addEventListener('astro:after-swap', reapply);
    </script>

    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    top: -80px;
    left: 1rem;
    z-index: 1000;
    padding: 0.6rem 1rem;
    background: var(--gold-300);
    color: var(--bg-void);
    font-family: var(--font-display);
    font-weight: 600;
    border-radius: 2px;
    transition: top var(--dur-base) var(--ease-standard);
  }

  .skip-link:focus {
    top: 1rem;
  }

  main {
    min-height: calc(100vh - 100px);
  }

  .section {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  @media (min-width: 768px) {
    .section {
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }
  }

  .section-y-lg {
    padding-top: 3.5rem;
    padding-bottom: 3.5rem;
  }

  .section-y-md {
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .section-y-lg {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }

    .section-y-md {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }
  }
</style>
