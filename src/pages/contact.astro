---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RevealOnScroll from "@/components/islands/RevealOnScroll.tsx";
import { site, socials } from "@/data/site";

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
---

<BaseLayout
  title="Contact"
  description="Send word — message Joseph Baker for work, collaboration, or freelance through Baker Software Solutions."
>
  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer></script>

  <section class="section section-y-lg contact-section">
    <div class="monument">
      <div class="monument-frieze monument-frieze--top" aria-hidden="true">
        <span class="monument-rune">✉</span>
      </div>

      <RevealOnScroll client:visible>
        <p class="section-eyebrow">Ravenroost · Contact</p>
        <h1 class="contact-h1 contact-h1--carved">Send word</h1>
        <p class="contact-sub">
          The candle's lit, the ink is wet. Write the letter, seal it, and the
          courier carries it straight to my inbox — no mail client needed.
        </p>
      </RevealOnScroll>

      <!-- ================================================================
           DESK — wood surface with candle + inkwell props on top,
           parchment sits in the middle and holds the form.
           ================================================================ -->
      <RevealOnScroll client:visible delayMs={150}>
        <div class="desk" id="desk" data-state="idle">
          <div class="candle candle--left" aria-hidden="true">
            <img
              src="/images/contact/candle.png"
              alt=""
              width="48"
              height="96"
              loading="eager"
              decoding="async"
            />
          </div>

          <div class="candle candle--right" aria-hidden="true">
            <img
              src="/images/contact/candle.png"
              alt=""
              width="48"
              height="96"
              loading="eager"
              decoding="async"
            />
          </div>

          <div class="inkwell" aria-hidden="true">
            <img
              src="/images/contact/inkwell.png"
              alt=""
              width="96"
              height="96"
              loading="eager"
              decoding="async"
            />
          </div>

          <div class="candle-glow-left" aria-hidden="true"></div>
          <div class="candle-glow-right" aria-hidden="true"></div>

          <!-- ============================================================
               PARCHMENT — holds the form. Animates into a rolled scroll
               on "Seal the letter" click.
               ============================================================ -->
          <div class="parchment" id="parchment">
            <div class="scroll-tube scroll-tube--top" aria-hidden="true"></div>
            <div class="scroll-tube scroll-tube--bottom" aria-hidden="true">
            </div>
            <div class="scroll-ribbon" aria-hidden="true"></div>
            <div class="wax-seal" aria-hidden="true">
              <svg viewBox="0 0 80 80" width="80" height="80">
                <defs>
                  <radialGradient id="wax-grad" cx="40%" cy="35%" r="65%">
                    <stop offset="0%" stop-color="#c42828"></stop>
                    <stop offset="60%" stop-color="#8b0000"></stop>
                    <stop offset="100%" stop-color="#4a0000"></stop>
                  </radialGradient>
                </defs>
                <circle cx="40" cy="40" r="34" fill="url(#wax-grad)"></circle>
                <circle
                  cx="40"
                  cy="40"
                  r="34"
                  fill="none"
                  stroke="#2a0000"
                  stroke-width="1.5"
                  opacity="0.6"></circle>
                <text
                  x="40"
                  y="50"
                  text-anchor="middle"
                  font-family="Cinzel, Georgia, serif"
                  font-size="30"
                  font-weight="700"
                  fill="#f0b90b"
                  opacity="0.92">JB</text
                >
                <circle cx="10" cy="58" r="5" fill="#8b0000" opacity="0.75"
                ></circle>
                <circle cx="70" cy="20" r="3" fill="#8b0000" opacity="0.6"
                ></circle>
                <circle cx="68" cy="62" r="4" fill="#8b0000" opacity="0.7"
                ></circle>
              </svg>
            </div>

            <div class="letter">
              <p class="letter-salutation">To Joseph of the Bakerverse,</p>

              <form id="contact-form" class="letter-form" novalidate>
                <div class="field">
                  <label for="name">Your name</label>
                  <input
                    id="name"
                    name="name"
                    type="text"
                    autocomplete="name"
                    maxlength="120"
                    required
                  />
                </div>

                <div class="field">
                  <label for="email">Where to reach you</label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    autocomplete="email"
                    maxlength="254"
                    required
                  />
                </div>

                <div class="field">
                  <label for="subject"
                    >Subject <span class="field-optional">— optional</span
                    ></label
                  >
                  <input
                    id="subject"
                    name="subject"
                    type="text"
                    maxlength="200"
                    placeholder="A word from a friend"
                    data-autofill-subject
                  />
                </div>

                <div class="field">
                  <label for="message">The letter itself</label>
                  <textarea
                    id="message"
                    name="message"
                    rows="6"
                    maxlength="5000"
                    required></textarea>
                </div>

                <div class="honeypot" aria-hidden="true">
                  <label for="hp">Leave this empty</label>
                  <input
                    id="hp"
                    name="hp"
                    type="text"
                    tabindex="-1"
                    autocomplete="off"
                  />
                </div>

                <div class="turnstile-wrap">
                  <div
                    class="cf-turnstile"
                    data-sitekey={turnstileSiteKey}
                    data-theme="dark"
                  >
                  </div>
                </div>

                <p
                  class="form-error"
                  id="form-error"
                  role="alert"
                  aria-live="polite"
                >
                </p>
              </form>
            </div>
          </div>

          <!-- Ritual CTA — lives OUTSIDE the parchment so it stays
               visible while the parchment collapses into a scroll.
               The `form` attribute keeps it as the form submit target. -->
          <div class="ritual" id="ritual">
            <button
              type="submit"
              form="contact-form"
              class="ritual-cta"
              id="ritual-cta"
              data-state="idle"
            >
              <span class="ritual-label" data-label="idle">Seal the letter</span
              >
              <span class="ritual-label" data-label="sealing">Sealing…</span>
              <span class="ritual-label" data-label="ready"
                >Send the letter</span
              >
              <span class="ritual-label" data-label="sending">Sending…</span>
              <span class="ritual-label" data-label="sent"
                >Sealed &amp; dispatched</span
              >
              <span class="ritual-icon" aria-hidden="true">
                <span class="ritual-icon-seal">✦</span>
                <span class="ritual-icon-send">➤</span>
                <span class="ritual-icon-sent">✓</span>
              </span>
            </button>
          </div>

          <!-- Courier animation intentionally omitted — revisit when
               we have a better-quality sprite or video. -->

          <div class="sent-card" id="sent-card" aria-live="polite">
            <p class="sent-eyebrow">✦ Dispatched</p>
            <h2 class="sent-title">Sealed &amp; dispatched</h2>
            <p class="sent-body">
              The courier has the letter. You'll hear back from
              <a href={`mailto:${site.email}`}>{site.email}</a> shortly.
            </p>
          </div>
        </div>
      </RevealOnScroll>

      <div class="monument-frieze monument-frieze--bottom" aria-hidden="true">
        <span class="monument-rune">✉</span>
      </div>
    </div>

    <RevealOnScroll client:visible delayMs={250}>
      <div class="socials-row">
        <p class="socials-label">Or find me elsewhere</p>
        <ul class="socials-list">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="social-link"
                  target={s.href.startsWith("http") ? "_blank" : undefined}
                  rel={
                    s.href.startsWith("http")
                      ? "noopener noreferrer"
                      : undefined
                  }
                >
                  <span class="social-glyph" aria-hidden="true">
                    {s.glyph}
                  </span>
                  <span class="social-body">
                    <span class="social-label">{s.label}</span>
                    <span class="social-handle">{s.handle}</span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </RevealOnScroll>

    <RevealOnScroll client:visible delayMs={300}>
      <aside class="guild-note">
        <span class="guild-crest" aria-hidden="true">◆</span>
        <div class="guild-body">
          <p class="guild-name">{site.business.name}</p>
          <p class="guild-tagline">
            Freelance and side engagements ride under this banner. Short-run
            builds, design-system work, or a second pair of hands on a mobile
            app — send word the same way.
          </p>
        </div>
      </aside>
    </RevealOnScroll>
  </section>
</BaseLayout>

<script>
  type State = "idle" | "sealing" | "ready" | "sending" | "sent";

  const form = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  const desk = document.getElementById("desk");
  const cta = document.getElementById("ritual-cta") as HTMLButtonElement | null;
  const errorBox = document.getElementById("form-error");
  const subjectInput = document.querySelector(
    "[data-autofill-subject]",
  ) as HTMLInputElement | null;
  const nameInput = document.getElementById("name") as HTMLInputElement | null;
  const emailInput = document.getElementById(
    "email",
  ) as HTMLInputElement | null;

  // Mirror the server's email regex so client + server agree on "valid".
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  if (form && desk && cta && errorBox) {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const SEAL_MS = prefersReducedMotion ? 0 : 900;

    const setState = (state: State) => {
      desk.setAttribute("data-state", state);
      cta.setAttribute("data-state", state);
    };

    const showError = (message: string) => {
      errorBox.textContent = message;
      errorBox.classList.add("is-visible");
    };

    const clearError = () => {
      errorBox.textContent = "";
      errorBox.classList.remove("is-visible");
    };

    if (nameInput && subjectInput) {
      const basePlaceholder = subjectInput.placeholder;
      nameInput.addEventListener("input", () => {
        const name = nameInput.value.trim();
        subjectInput.placeholder = name
          ? `A word from ${name}`
          : basePlaceholder;
      });
    }

    // Clear any custom email error while the user edits so the native
    // validation bubble disappears as soon as they fix the problem.
    if (emailInput) {
      emailInput.addEventListener("input", () => {
        emailInput.setCustomValidity("");
      });
    }

    const getTurnstileToken = (): string => {
      const hidden = form.querySelector<HTMLInputElement>(
        '[name="cf-turnstile-response"]',
      );
      return hidden?.value ?? "";
    };

    const resetTurnstile = () => {
      const w = (
        window as unknown as {
          turnstile?: { reset: (container?: Element | string) => void };
        }
      ).turnstile;
      if (w && typeof w.reset === "function") {
        const container = form.querySelector(".cf-turnstile");
        if (container) w.reset(container);
      }
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const state = cta.getAttribute("data-state") as State;

      if (state === "idle") {
        clearError();

        // Custom email check — regex stricter than the browser's
        // built-in `type="email"` (which accepts "a@b"). Attach the
        // message to the field so the browser shows the error arrow
        // pointing at the input, not a form-wide banner.
        if (emailInput) {
          const value = emailInput.value.trim();
          if (value && !EMAIL_RE.test(value)) {
            emailInput.setCustomValidity(
              "Please enter a valid email address (for example: name@domain.com).",
            );
          } else {
            emailInput.setCustomValidity("");
          }
        }

        if (!form.reportValidity()) return;

        const token = getTurnstileToken();
        if (!token) {
          showError(
            "The bot-check widget is still loading. Give it a second, then try again.",
          );
          return;
        }

        setState("sealing");

        // Scroll the desk to the top of the viewport so the rolled
        // scroll + the open stage below are both fully in view once
        // the animation finishes.
        desk.scrollIntoView({
          behavior: prefersReducedMotion ? "auto" : "smooth",
          block: "start",
        });

        window.setTimeout(() => {
          setState("ready");
        }, SEAL_MS);
        return;
      }

      if (state === "ready") {
        clearError();
        setState("sending");

        const data = new FormData(form);
        const payload = {
          name: String(data.get("name") ?? ""),
          email: String(data.get("email") ?? ""),
          subject: String(data.get("subject") ?? ""),
          message: String(data.get("message") ?? ""),
          hp: String(data.get("hp") ?? ""),
          turnstileToken: getTurnstileToken(),
        };

        try {
          const res = await fetch("/api/contact", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const body = (await res.json().catch(() => ({}))) as {
            ok?: boolean;
            error?: string;
          };

          if (!res.ok || body.ok !== true) {
            throw new Error(
              body.error ?? "Something went wrong sending the letter.",
            );
          }

          setState("sent");
        } catch (err) {
          const message =
            err instanceof Error
              ? err.message
              : "Something went wrong. Please try again.";
          showError(message);
          resetTurnstile();
          setState("ready");
        }
        return;
      }
    });
  }
</script>

<style>
  .contact-section {}

  .contact-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    margin: 1rem 0 1.25rem;
  }

  .contact-h1--carved {
    letter-spacing: 0.01em;
    text-shadow:
      0 1px 0 rgba(0, 0, 0, 0.65),
      0 -1px 0 rgba(240, 185, 11, 0.06);
  }

  .contact-sub {
    max-width: 40rem;
    margin: 0 0 3rem;
    color: var(--ink-300);
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .monument {
    position: relative;
    padding: 2rem 1.25rem 2.25rem;
    background:
      radial-gradient(
        ellipse at top,
        rgba(240, 185, 11, 0.05),
        transparent 60%
      ),
      linear-gradient(
        180deg,
        rgba(29, 26, 38, 0.35) 0%,
        rgba(13, 12, 20, 0) 100%
      );
  }

  @media (min-width: 720px) {
    .monument {
      padding: 2.5rem 2rem 2.75rem;
    }
  }

  .monument-frieze {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--gold-400);
  }

  .monument-frieze::before,
  .monument-frieze::after {
    content: "";
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(240, 185, 11, 0.35),
      transparent
    );
  }

  .monument-frieze--top {
    margin-bottom: 2rem;
  }
  .monument-frieze--bottom {
    margin-top: 2.25rem;
  }

  .monument-rune {
    font-size: 0.9rem;
    opacity: 0.75;
  }

  /* =========================================================
     Desk — dark walnut slab with candle + inkwell on top
     ========================================================= */
  .desk {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    padding: 5rem 2rem 3rem;
    /* Tall enough that when the parchment rolls up and floats to the
       top there's a clear open stage below for the courier animation
       (and later a real horse sprite). */
    min-height: 760px;
    background:
      linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.4) 0%,
        transparent 3%,
        transparent 97%,
        rgba(0, 0, 0, 0.5) 100%
      ),
      radial-gradient(
        ellipse at 10% 0%,
        rgba(240, 185, 11, 0.18) 0%,
        transparent 45%
      ),
      repeating-linear-gradient(
        92deg,
        rgba(255, 220, 140, 0.02) 0 2px,
        transparent 2px 5px,
        rgba(0, 0, 0, 0.06) 5px 7px,
        transparent 7px 12px
      ),
      linear-gradient(
        180deg,
        #2f1d10 0%,
        #3d2714 30%,
        #4a2f18 60%,
        #331e0d 100%
      );
    border: 1px solid #1a0f05;
    border-radius: 4px;
    box-shadow:
      0 40px 100px -40px rgba(0, 0, 0, 0.95),
      inset 0 2px 0 rgba(255, 200, 120, 0.08),
      inset 0 -4px 20px rgba(0, 0, 0, 0.6),
      inset 0 0 0 1px rgba(240, 185, 11, 0.06);
    /* overflow: visible so the candle flames can peek above the
       desk's top edge. The messenger now clips itself via
       .messenger-stage; parchment clips its own scroll animation. */
    overflow: visible;
    isolation: isolate;
  }

  /* Pixel art props — display at 2× source for crisp nearest-neighbor
     scaling. Gentle brightness + drop-shadow pulse on the candle gives
     the static flame enough life until we have a real frame cycle. */
  .candle {
    position: absolute;
    /* Negative top so the flame peeks above the desk's top edge,
       enabled by .desk overflow: visible. Source art is 48×96;
       width is fluid and height is derived from the 1:2 aspect
       ratio so pixel proportions stay correct on narrow viewports. */
    top: -2rem;
    width: clamp(56px, 16vw, 96px);
    aspect-ratio: 1 / 2;
    z-index: 2;
    pointer-events: none;
  }

  .candle--left {
    left: 0.5rem;
  }
  .candle--right {
    right: 0.5rem;
  }

  .candle img {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    filter: drop-shadow(0 0 14px rgba(240, 185, 11, 0.55))
      drop-shadow(0 0 28px rgba(240, 185, 11, 0.25));
    animation: candle-pulse 2.1s ease-in-out infinite;
    transform-origin: 50% 100%;
  }

  @keyframes candle-pulse {
    0%,
    100% {
      filter: drop-shadow(0 0 14px rgba(240, 185, 11, 0.55))
        drop-shadow(0 0 28px rgba(240, 185, 11, 0.25));
      transform: scale(1);
    }
    40% {
      filter: drop-shadow(0 0 10px rgba(240, 185, 11, 0.4))
        drop-shadow(0 0 20px rgba(240, 185, 11, 0.18));
      transform: scale(0.995);
    }
    70% {
      filter: drop-shadow(0 0 18px rgba(240, 185, 11, 0.7))
        drop-shadow(0 0 34px rgba(240, 185, 11, 0.3));
      transform: scale(1.01);
    }
  }

  .inkwell {
    position: absolute;
    /* Centered at top of the desk, between the two candles. */
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(80px, 24vw, 128px);
    aspect-ratio: 1 / 1;
    z-index: 2;
    pointer-events: none;
  }

  .inkwell img {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.55));
  }

  .candle-glow-left {
    position: absolute;
    top: -80px;
    left: -60px;
    width: 340px;
    height: 340px;
    pointer-events: none;
    background: radial-gradient(
      circle at center,
      rgba(255, 217, 104, 0.28) 0%,
      rgba(240, 185, 11, 0.08) 40%,
      transparent 70%
    );
    mix-blend-mode: screen;
    animation: candle-glow-flicker 3.8s ease-in-out infinite;
    z-index: 1;
  }

  .candle-glow-right {
    position: absolute;
    top: -80px;
    right: -60px;
    width: 340px;
    height: 340px;
    pointer-events: none;
    background: radial-gradient(
      circle at center,
      rgba(255, 217, 104, 0.28) 0%,
      rgba(240, 185, 11, 0.08) 40%,
      transparent 70%
    );
    mix-blend-mode: screen;
    animation: candle-glow-flicker 3.8s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes candle-glow-flicker {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.8;
    }
  }

  /* =========================================================
     Parchment — transitions to a rolled scroll on submit
     ========================================================= */
  .parchment {
    position: relative;
    /* Narrower + pushed down so the centered inkwell (top) and the
       candles (left + right corners) all stay fully visible. */
    max-width: 440px;
    margin: 8rem auto 1rem;
    padding: 2.5rem 2rem 2rem;
    background:
      radial-gradient(
        ellipse at 20% 20%,
        rgba(240, 185, 11, 0.08),
        transparent 60%
      ),
      radial-gradient(
        ellipse at 80% 90%,
        rgba(139, 0, 0, 0.06),
        transparent 60%
      ),
      repeating-linear-gradient(
        135deg,
        rgba(240, 185, 11, 0.015) 0 2px,
        transparent 2px 5px
      ),
      linear-gradient(180deg, #f2e4c1 0%, #e9d4a6 50%, #d6ba85 100%);
    color: #3b2a16;
    border: 1px solid rgba(90, 60, 20, 0.5);
    border-radius: 2px;
    box-shadow:
      0 30px 60px -20px rgba(0, 0, 0, 0.8),
      0 8px 24px -8px rgba(0, 0, 0, 0.5),
      inset 0 0 80px -20px rgba(92, 65, 5, 0.35),
      inset 0 0 0 1px rgba(240, 185, 11, 0.1);
    transition:
      transform 700ms var(--ease-ornate),
      max-height 700ms var(--ease-ornate),
      padding 700ms var(--ease-ornate),
      filter var(--dur-base) var(--ease-standard),
      opacity var(--dur-base) var(--ease-standard);
    max-height: 900px;
    overflow: hidden;
    isolation: isolate;
    z-index: 3;
  }

  .letter {
    transition:
      opacity 250ms var(--ease-standard),
      transform 400ms var(--ease-ornate);
    transform-origin: top center;
  }

  .letter-salutation {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    color: #5c4105;
    margin: 0 0 1.5rem;
    text-align: center;
  }

  /* Form fields — parchment-tinted, intentionally uncommon */
  .letter-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .field label {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8a6208;
  }

  .field-optional {
    color: #9b7d3e;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: none;
    font-size: 0.8em;
  }

  .field input,
  .field textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: #2a1a08;
    background: rgba(255, 251, 235, 0.55);
    border: 1px solid rgba(92, 65, 5, 0.35);
    border-bottom: 1px solid rgba(92, 65, 5, 0.6);
    border-radius: 2px;
    padding: 0.6rem 0.75rem;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-fast) var(--ease-standard);
    width: 100%;
  }

