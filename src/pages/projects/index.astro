---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TooltipCard from '@/components/ui/TooltipCard.astro';
import StackBadge from '@/components/ui/StackBadge.astro';
import RevealOnScroll from '@/components/islands/RevealOnScroll.tsx';
import ThemeSwitcherMini from '@/components/islands/ThemeSwitcherMini.tsx';
import { getCollection, type CollectionEntry } from 'astro:content';

type Quest = CollectionEntry<'projects'>;

const quests = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);

const active = quests.filter(
  (q) => q.data.status === 'active' || q.data.status === 'wip' || q.data.status === 'paused',
);
const completed = quests.filter((q) => q.data.status === 'shipped');
const upcoming = quests.filter((q) => q.data.status === 'upcoming');

const statusCopy: Record<string, string> = {
  active: '◆ Currently active',
  shipped: '✔ Shipped',
  wip: '⚒ In the forge',
  archived: '✶ Archived',
  upcoming: '☽ Next on the roll',
  paused: '⏸ On hold',
};

const featuredActive = active[0];
const otherActive = active.slice(1);
---

<BaseLayout
  title="Quest Log"
  description="Every quest Joseph Baker has undertaken — active campaigns, completed work, and upcoming adventures."
>
  <!-- ======================================================
       INTRO — monument framing, matches /work
       ====================================================== -->
  <section class="section section-y-md quest-intro">
    <div class="monument">
      <div class="monument-frieze monument-frieze--top" aria-hidden="true">
        <span class="monument-rune">◆</span>
      </div>

      <RevealOnScroll client:visible>
        <p class="section-eyebrow">Quest Log</p>
        <h1 class="quest-h1 quest-h1--carved">Quests undertaken</h1>
      </RevealOnScroll>

      <RevealOnScroll client:visible delayMs={200}>
        <p class="quest-sub">
          Every build, every campaign, every side-quest. Tap any entry to
          unroll the journal and read what it cost, what it taught, and
          what it shipped.
        </p>
      </RevealOnScroll>

      <div class="monument-frieze monument-frieze--bottom" aria-hidden="true">
        <span class="monument-rune">◆</span>
      </div>
    </div>
  </section>

  <!-- ======================================================
       ACTIVE QUEST — Theme Engine spotlight + any others
       ====================================================== -->
  <section class="section section-y-md quest-section" aria-label="Active quests">
    <RevealOnScroll client:visible>
      <div class="quest-group-head">
        <p class="section-eyebrow">Active Quest</p>
        <h2 class="quest-group-h2">In the forge right now</h2>
      </div>
    </RevealOnScroll>

    {featuredActive && (
      <RevealOnScroll client:visible delayMs={80}>
        <div
          class={`bento-hero${featuredActive.slug !== 'theme-engine' ? ' bento-hero--no-island' : ''}`}
          style={`--bento-color: var(--rarity-${featuredActive.data.rarity});`}
        >
          <div class="bento-hero__content">
            <div class="bento-hero__head">
              <span
                class="bento-hero__rarity"
                style={`color: var(--rarity-${featuredActive.data.rarity});`}
              >
                {featuredActive.data.rarity} · {featuredActive.data.year}
              </span>
              <span class="bento-hero__status">◆ Currently active</span>
            </div>

            <h3 class="bento-hero__title">{featuredActive.data.title}</h3>
            <p class="bento-hero__tagline">{featuredActive.data.tagline}</p>
            <p class="bento-hero__summary">{featuredActive.data.summary}</p>

            <div class="bento-hero__stack">
              {featuredActive.data.stack.map((tech: string) => (
                <StackBadge label={tech} />
              ))}
            </div>

            <a href={`/projects/${featuredActive.slug}`} class="bento-hero__cta">
              Read the case study →
            </a>
          </div>

          {featuredActive.slug === 'theme-engine' && (
            <div class="bento-hero__island">
              <ThemeSwitcherMini client:visible />
            </div>
          )}
        </div>
      </RevealOnScroll>
    )}

    {otherActive.length > 0 && (
      <div class="quest-grid quest-grid--featured" style="margin-top: 1.5rem;">
        {otherActive.map((quest, index) => (
          <RevealOnScroll client:visible delayMs={index * 100}>
            <TooltipCard
              href={`/projects/${quest.slug}`}
              rarity={quest.data.rarity}
              class="quest-card"
            >
              <article data-rarity={quest.data.rarity}>
                <div class="quest-card-head">
                  <span class="quest-rarity">{quest.data.rarity}</span>
                  <span class="quest-year">{quest.data.year}</span>
                </div>
                <h3 class="quest-title">{quest.data.title}</h3>
                <p class="quest-tagline">{quest.data.tagline}</p>
                <div class="quest-stack">
                  {quest.data.stack.slice(0, 5).map((tech) => (
                    <StackBadge label={tech} />
                  ))}
                </div>
                <div class="quest-footer">
                  <span class="quest-status" data-status={quest.data.status}>
                    {statusCopy[quest.data.status] ?? quest.data.status}
                  </span>
                  <span class="quest-cta">Open journal →</span>
                </div>
              </article>
            </TooltipCard>
          </RevealOnScroll>
        ))}
      </div>
    )}

    {!featuredActive && otherActive.length === 0 && (
      <RevealOnScroll client:visible delayMs={80}>
        <p class="quest-empty-state">
          No active quests right now. The forge is quiet — for the moment.
        </p>
      </RevealOnScroll>
    )}
  </section>

  <!-- ======================================================
       UPCOMING QUESTS
       ====================================================== -->
  <section class="section section-y-md quest-section" aria-label="Upcoming quests">
    <RevealOnScroll client:visible>
      <div class="quest-group-head">
        <p class="section-eyebrow">Upcoming</p>
        <h2 class="quest-group-h2">Next on the campaign roll</h2>
      </div>
    </RevealOnScroll>

    {upcoming.length > 0 ? (
      <div class="quest-grid">
        {upcoming.map((quest, index) => (
          <RevealOnScroll client:visible delayMs={index * 60}>
            <TooltipCard
              href={`/projects/${quest.slug}`}
              rarity={quest.data.rarity}
              class="quest-card"
            >
              <article data-rarity={quest.data.rarity}>
                <div class="quest-card-head">
                  <span class="quest-rarity">{quest.data.rarity}</span>
                  <span class="quest-year">{quest.data.year}</span>
                </div>
                <h3 class="quest-title">{quest.data.title}</h3>
                <p class="quest-tagline">{quest.data.tagline}</p>
                <div class="quest-stack">
                  {quest.data.stack.slice(0, 4).map((tech) => (
                    <StackBadge label={tech} />
                  ))}
                </div>
              </article>
            </TooltipCard>
          </RevealOnScroll>
        ))}
      </div>
    ) : (
      <RevealOnScroll client:visible delayMs={80}>
        <p class="quest-empty-state">
          No current upcoming quests. The next adventure hasn't been
          scrolled yet — check back soon.
        </p>
      </RevealOnScroll>
    )}
  </section>

  <!-- ======================================================
       COMPLETED QUESTS
       ====================================================== -->
  <section class="section section-y-md quest-section" aria-label="Completed quests">
    <RevealOnScroll client:visible>
      <div class="quest-group-head">
        <p class="section-eyebrow">Completed</p>
        <h2 class="quest-group-h2">Quests on the books</h2>
      </div>
    </RevealOnScroll>

    {completed.length > 0 ? (
      <div class="quest-grid">
        {completed.map((quest, index) => (
          <RevealOnScroll client:visible delayMs={index * 60}>
            <TooltipCard
              href={`/projects/${quest.slug}`}
              rarity={quest.data.rarity}
              class="quest-card"
            >
              <article data-rarity={quest.data.rarity}>
                <div class="quest-card-head">
                  <span class="quest-rarity">{quest.data.rarity}</span>
                  <span class="quest-year">{quest.data.year}</span>
                </div>
                <h3 class="quest-title">{quest.data.title}</h3>
                <p class="quest-tagline">{quest.data.tagline}</p>
                <div class="quest-stack">
                  {quest.data.stack.slice(0, 4).map((tech) => (
                    <StackBadge label={tech} />
                  ))}
                </div>
                <div class="quest-footer">
                  <span class="quest-status" data-status={quest.data.status}>
                    {statusCopy[quest.data.status] ?? quest.data.status}
                  </span>
                  <span class="quest-cta">Open →</span>
                </div>
              </article>
            </TooltipCard>
          </RevealOnScroll>
        ))}
      </div>
    ) : (
      <RevealOnScroll client:visible delayMs={80}>
        <p class="quest-empty-state">
          No completed quests yet. The first will appear here the moment it
          ships.
        </p>
      </RevealOnScroll>
    )}
  </section>
</BaseLayout>

<style>
  .quest-intro {}

  .quest-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    margin: 1rem 0 2rem;
  }

  .quest-h1--carved {
    letter-spacing: 0.01em;
    text-shadow:
      0 1px 0 rgba(0, 0, 0, 0.65),
      0 -1px 0 rgba(240, 185, 11, 0.06);
  }

  .quest-sub {
    color: var(--ink-300);
    line-height: 1.7;
    font-size: 1.05rem;
    max-width: 38rem;
  }

  .monument {
    position: relative;
    padding: 1.75rem 1.25rem 1.5rem;
    background:
      radial-gradient(
        ellipse at top,
        rgba(240, 185, 11, 0.05),
        transparent 60%
      ),
      linear-gradient(
        180deg,
        rgba(29, 26, 38, 0.35) 0%,
        rgba(13, 12, 20, 0) 100%
      );
  }

  @media (min-width: 720px) {
    .monument {
      padding: 2rem 2rem 1.75rem;
    }
  }

  .monument-frieze {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--gold-400);
  }

  .monument-frieze::before,
  .monument-frieze::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(240, 185, 11, 0.35),
      transparent
    );
  }

  .monument-frieze--top {
    margin-bottom: 1.5rem;
  }

  .monument-frieze--bottom {
    margin-top: 1.5rem;
  }

  .monument-rune {
    font-size: 0.9rem;
    opacity: 0.75;
  }

  .quest-section {}

  .quest-group-head {
    margin-bottom: 1.5rem;
  }

  .quest-group-h2 {
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    margin: 0.5rem 0 0.75rem;
    line-height: 1.15;
  }

  .quest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .quest-grid--featured {
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }

  .quest-card {
    height: 100%;
  }

  .quest-card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .quest-rarity {
    color: var(--rarity-color);
  }

  .quest-year {
    color: var(--ink-500);
  }

  .quest-title {
    font-size: 1.25rem;
    line-height: 1.25;
    margin: 0 0 0.5rem;
    color: var(--ink-100);
  }

  .quest-tagline {
    color: var(--ink-300);
    line-height: 1.5;
    margin: 0 0 1rem;
    font-size: 0.95rem;
  }

  .quest-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .quest-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .quest-status {
    color: var(--ink-500);
  }

  .quest-status[data-status='active'] {
    color: var(--rarity-uncommon);
  }

  .quest-status[data-status='wip'] {
    color: var(--gold-300);
  }

  .quest-status[data-status='paused'] {
    color: var(--ink-400);
  }

  .quest-cta {
    color: var(--gold-300);
    transition: transform 180ms ease;
  }

  .quest-card:hover .quest-cta {
    transform: translateX(2px);
  }

  /* Empty-state copy for sections with no quests yet. */
  .quest-empty-state {
    color: var(--ink-500);
    font-style: italic;
    line-height: 1.6;
    padding: 1.5rem 1.5rem;
    max-width: 52ch;
    border: 1px dashed rgba(255, 255, 255, 0.08);
    border-radius: 0.375rem;
    background: rgba(29, 26, 38, 0.35);
    margin: 0;
  }

  /* ── Theme Engine bento hero ──────────────────── */
  .bento-hero {
    display: grid;
    gap: 1.5rem;
    padding: 1.75rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--bento-color) 30%, transparent);
    background:
      radial-gradient(ellipse at top right, color-mix(in srgb, var(--bento-color) 7%, transparent), transparent 60%),
      linear-gradient(180deg, rgba(29, 26, 38, 0.8) 0%, rgba(13, 12, 20, 0.95) 100%);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--bento-color) 10%, transparent) inset,
      0 8px 32px rgba(0, 0, 0, 0.4);
  }

  @media (min-width: 900px) {
    .bento-hero {
      grid-template-columns: 1fr 340px;
      align-items: start;
    }

    .bento-hero--no-island {
      grid-template-columns: 1fr;
    }
  }

  .bento-hero__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .bento-hero__rarity {
    font-weight: 600;
  }

  .bento-hero__status {
    color: var(--rarity-uncommon);
  }

  .bento-hero__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.2;
    color: var(--ink-100);
    margin: 0 0 0.5rem;
  }

  .bento-hero__tagline {
    color: color-mix(in srgb, var(--bento-color) 80%, white);
    font-size: 1.05rem;
    line-height: 1.5;
    margin: 0 0 0.75rem;
    font-style: italic;
  }

  .bento-hero__summary {
    color: var(--ink-300);
    line-height: 1.7;
    font-size: 0.95rem;
    margin: 0 0 1.25rem;
    max-width: 54ch;
  }

  .bento-hero__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1.25rem;
  }

  .bento-hero__cta {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border: 1px solid color-mix(in srgb, var(--bento-color) 60%, transparent);
    border-radius: 0.3rem;
    color: color-mix(in srgb, var(--bento-color) 80%, white);
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: border-color 180ms ease, color 180ms ease, background 180ms ease;
  }

  .bento-hero__cta:hover {
    border-color: var(--bento-color);
    color: color-mix(in srgb, var(--bento-color) 60%, white);
    background: color-mix(in srgb, var(--bento-color) 10%, transparent);
  }

  .bento-hero__island {
    padding: 1.25rem;
    border-radius: 0.375rem;
    background: rgba(13, 12, 20, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
</style>
