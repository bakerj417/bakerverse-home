---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdventureEntry from '@/components/work/AdventureEntry.astro';
import RevealOnScroll from '@/components/islands/RevealOnScroll.tsx';
import MagneticButton from '@/components/islands/MagneticButton.tsx';
import { getCollection } from 'astro:content';
import { site } from '@/data/site';

const roles = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order,
);

const current = roles.filter((r) => r.data.active);
const past = roles.filter((r) => !r.data.active);
---

<BaseLayout
  title="Work"
  description="Joseph Baker's adventure log — the current campaign and every stop that got me here."
>
  <!-- ======================================================
       INTRO — monument framing, matches /about
       ====================================================== -->
  <section class="section section-y-md work-intro">
    <div class="monument">
      <div class="monument-frieze monument-frieze--top" aria-hidden="true">
        <span class="monument-rune">⚔</span>
      </div>

      <RevealOnScroll client:visible>
        <p class="section-eyebrow">Adventure Log</p>
        <h1 class="work-h1 about-h1--carved">The adventures so far</h1>
      </RevealOnScroll>

      <RevealOnScroll client:visible delayMs={200}>
        <p class="work-sub">
          Fifteen years of shipping software — the current campaign, the
          side quests, and the long trail of adventures that got me here.
          Tap any entry to unroll the full record.
        </p>
      </RevealOnScroll>

      <div class="monument-frieze monument-frieze--bottom" aria-hidden="true">
        <span class="monument-rune">⚔</span>
      </div>
    </div>
  </section>

  <!-- ======================================================
       CURRENT ADVENTURE
       ====================================================== -->
  {current.length > 0 && (
    <section class="section section-y-md adventure-section">
      <RevealOnScroll client:visible>
        <div class="adventure-group-head">
          <p class="section-eyebrow">Current Chapter</p>
          <h2 class="adventure-group-h2">My Current Adventure</h2>
        </div>
      </RevealOnScroll>

      <div class="adventure-list adventure-list--solo">
        {current.map((role) => (
          <RevealOnScroll client:visible>
            <AdventureEntry role={role} variant="current" />
          </RevealOnScroll>
        ))}
      </div>
    </section>
  )}

  <!-- ======================================================
       ADVENTURES LONG PAST
       ====================================================== -->
  {past.length > 0 && (
    <section class="section section-y-md adventure-section">
      <RevealOnScroll client:visible>
        <div class="adventure-group-head">
          <p class="section-eyebrow">Chapters Past</p>
          <h2 class="adventure-group-h2">Adventures Long Past</h2>
          <p class="adventure-group-sub">
            Roles, stacks, and the things I shipped. Collapsed for
            scanning — unroll any that catch your eye.
          </p>
        </div>
      </RevealOnScroll>

      <div class="adventure-list">
        {past.map((role, index) => (
          <RevealOnScroll client:visible delayMs={index * 60}>
            <AdventureEntry role={role} variant="past" />
          </RevealOnScroll>
        ))}
      </div>
    </section>
  )}

  <!-- ======================================================
       RESUME CTA
       ====================================================== -->
  <section class="section section-y-md">
    <RevealOnScroll client:visible>
      <aside class="work-footer-cta">
        <p>
          Want the full history in printable form? The resume has every
          stop, every stack, and every notable deed on a single scroll.
        </p>
        <div class="work-footer-ctas">
          <MagneticButton
            client:load
            href={site.resumeUrl}
            external
            variant="gold"
            ariaLabel="Download resume"
          >
            Unroll Resume <span aria-hidden="true">⤓</span>
          </MagneticButton>
        </div>
      </aside>
    </RevealOnScroll>
  </section>
</BaseLayout>

<style>
  .work-intro {
    max-width: 820px;
  }

  .work-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    margin: 1rem 0 2rem;
  }

  /* -------- MONUMENT framing (shared w/ /about) -------- */
  .monument {
    position: relative;
    padding: 1.75rem 1.25rem 1.5rem;
    background:
      radial-gradient(
        ellipse at top,
        rgba(240, 185, 11, 0.05),
        transparent 60%
      ),
      linear-gradient(
        180deg,
        rgba(29, 26, 38, 0.35) 0%,
        rgba(13, 12, 20, 0) 100%
      );
  }

  @media (min-width: 720px) {
    .monument {
      padding: 2rem 2rem 1.75rem;
    }
  }

  .monument-frieze {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--gold-400);
  }

  .monument-frieze::before,
  .monument-frieze::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(240, 185, 11, 0.35),
      transparent
    );
  }

  .monument-frieze--top {
    margin-bottom: 1.5rem;
  }

  .monument-frieze--bottom {
    margin-top: 1.5rem;
  }

  .monument-rune {
    font-size: 0.9rem;
    opacity: 0.75;
  }

  .about-h1--carved {
    letter-spacing: 0.01em;
    text-shadow:
      0 1px 0 rgba(0, 0, 0, 0.65),
      0 -1px 0 rgba(240, 185, 11, 0.06);
  }

  .work-sub {
    color: var(--ink-300);
    line-height: 1.7;
    font-size: 1.05rem;
    max-width: 38rem;
  }

  /* -------- GROUP HEADS -------- */
  .adventure-section {
    max-width: 940px;
    margin: 0 auto;
  }

  .adventure-group-head {
    margin-bottom: 1.5rem;
  }

  .adventure-group-h2 {
    font-size: clamp(1.75rem, 3.2vw, 2.5rem);
    margin: 0.5rem 0 0.75rem;
    line-height: 1.15;
  }

  .adventure-group-sub {
    color: var(--ink-400);
    font-size: 0.97rem;
    line-height: 1.6;
    max-width: 42rem;
    margin: 0;
  }

  /* -------- LIST -------- */
  .adventure-list {
    display: grid;
    gap: 1rem;
  }

  .adventure-list--solo {
    gap: 0;
  }

  /* -------- footer CTA -------- */
  .work-footer-cta {
    max-width: 940px;
    margin: 2rem auto 0;
    padding: 2rem;
    text-align: center;
    background: rgba(29, 26, 38, 0.5);
    border: 1px solid rgba(240, 185, 11, 0.1);
    border-radius: 2px;
  }

  .work-footer-cta p {
    color: var(--ink-300);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 42rem;
    margin: 0 auto 1.25rem;
  }

  .work-footer-ctas {
    display: flex;
    justify-content: center;
  }
</style>
