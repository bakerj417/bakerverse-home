---
import { nav, site } from '@/data/site';
const { pathname } = Astro.url;
---

<header class="nav-root" data-nav-root>
  <a href="/" class="nav-brand" aria-label="Joseph Baker — home">
    <span class="nav-monogram" aria-hidden="true">JB</span>
    <span class="nav-brand-text">
      <span class="nav-brand-name">{site.name}</span>
      <span class="nav-brand-tagline">Bakerverse · Est. 2026</span>
    </span>
  </a>

  <button
    type="button"
    class="nav-toggle"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="primary-nav"
    data-nav-toggle
  >
    <span class="nav-toggle-bar" aria-hidden="true"></span>
    <span class="nav-toggle-bar" aria-hidden="true"></span>
    <span class="nav-toggle-bar" aria-hidden="true"></span>
  </button>

  <nav
    id="primary-nav"
    class="nav-links"
    aria-label="Primary"
    data-nav-panel
  >
    {nav.map((item) => {
      const isActive =
        item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);
      return (
        <a
          href={item.href}
          class:list={['nav-link', isActive && 'is-active']}
          aria-current={isActive ? 'page' : undefined}
        >
          <span class="nav-glyph" aria-hidden="true">{item.glyph}</span>
          <span class="nav-label">{item.label}</span>
        </a>
      );
    })}
    <a
      href={site.resumeUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-gold nav-resume nav-resume--panel"
    >
      <span>Resume</span>
      <span aria-hidden="true">⤓</span>
    </a>
  </nav>

  <a
    href={site.resumeUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="btn-gold nav-resume nav-resume--desktop"
  >
    <span>Resume</span>
    <span aria-hidden="true">⤓</span>
  </a>
</header>

<script>
  const root = document.querySelector<HTMLElement>('[data-nav-root]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-nav-panel]');

  if (root && toggle && panel) {
    const close = () => {
      root.removeAttribute('data-nav-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      document.body.style.overflow = '';
    };

    const open = () => {
      root.setAttribute('data-nav-open', '');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      document.body.style.overflow = 'hidden';
    };

    toggle.addEventListener('click', () => {
      if (root.hasAttribute('data-nav-open')) close();
      else open();
    });

    panel.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
      link.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && root.hasAttribute('data-nav-open')) close();
    });

    const mq = window.matchMedia('(min-width: 900px)');
    mq.addEventListener('change', (e) => {
      if (e.matches) close();
    });
  }
</script>

<style>
  .nav-root {
    position: sticky;
    top: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1.1rem;
    background: linear-gradient(180deg, rgba(7, 6, 10, 0.92) 0%, rgba(7, 6, 10, 0.7) 80%, transparent 100%);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(240, 185, 11, 0.08);
  }

  @media (min-width: 900px) {
    .nav-root {
      gap: 2rem;
      padding: 1rem 2rem;
    }
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink-100);
    min-width: 0;
  }

  .nav-brand:hover {
    color: var(--ink-100);
  }

  .nav-monogram {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--gold-200);
    background:
      radial-gradient(circle at 30% 30%, rgba(240, 185, 11, 0.2), transparent 70%),
      linear-gradient(180deg, rgba(29, 26, 38, 0.9), rgba(13, 12, 20, 0.95));
    border: 1px solid var(--gold-500);
    border-radius: 2px;
    box-shadow: var(--shadow-gold-glow);
  }

  .nav-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    min-width: 0;
  }

  .nav-brand-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink-100);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .nav-brand-tagline {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--ink-500);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* -------- HAMBURGER TOGGLE (mobile only) -------- */
  .nav-toggle {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    background: transparent;
    border: 1px solid rgba(240, 185, 11, 0.25);
    border-radius: 2px;
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-standard);
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0;
  }

  .nav-toggle:hover {
    border-color: var(--gold-400);
  }

  .nav-toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--gold-300);
    border-radius: 1px;
    transition:
      transform var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard);
  }

  @media (min-width: 900px) {
    .nav-toggle {
      display: none;
    }
  }

  /* Toggle becomes an X when panel is open */
  .nav-root[data-nav-open] .nav-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-root[data-nav-open] .nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .nav-root[data-nav-open] .nav-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* -------- NAV LINKS PANEL -------- */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  /* Mobile: the panel lives under the header. Hidden by default via
     visibility + scaleY, animated open/closed via transitions. */
  @media (max-width: 899px) {
    .nav-links {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      padding: 1rem 1rem 1.25rem;
      background: linear-gradient(
        180deg,
        rgba(7, 6, 10, 0.98) 0%,
        rgba(13, 12, 20, 0.98) 100%
      );
      border-bottom: 1px solid rgba(240, 185, 11, 0.15);
      box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.85);
      max-height: calc(100vh - 60px);
      overflow-y: auto;
      /* closed state */
      visibility: hidden;
      opacity: 0;
      transform: scaleY(0.92) translateY(-6px);
      transform-origin: top center;
      pointer-events: none;
      transition:
        opacity 200ms var(--ease-ornate),
        transform 240ms var(--ease-ornate),
        visibility 0s linear 260ms;
    }

    .nav-root[data-nav-open] .nav-links {
      visibility: visible;
      opacity: 1;
      transform: scaleY(1) translateY(0);
      pointer-events: auto;
      transition:
        opacity 180ms var(--ease-ornate),
        transform 380ms cubic-bezier(0.16, 1, 0.3, 1),
        visibility 0s linear 0s;
    }

    /* Gold rune seal — a hairline of gold that sweeps across the
       top of the panel as it opens. */
    .nav-links::before {
      content: "";
      position: absolute;
      top: 0;
      left: 5%;
      right: 5%;
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(240, 185, 11, 0.55) 18%,
        rgba(255, 237, 176, 0.95) 50%,
        rgba(240, 185, 11, 0.55) 82%,
        transparent 100%
      );
      box-shadow: 0 0 14px 2px rgba(240, 185, 11, 0.4);
      transform: scaleX(0);
      transform-origin: center;
      transition: transform 440ms cubic-bezier(0.16, 1, 0.3, 1) 40ms;
      pointer-events: none;
    }

    .nav-root[data-nav-open] .nav-links::before {
      transform: scaleX(1);
    }

    /* Cascade reveal: each nav link / the resume CTA slide in with a
       tiny x-offset so the menu feels etched in, not dumped in. */
    .nav-link,
    .nav-resume--panel {
      opacity: 0;
      transform: translateX(-10px);
      transition:
        opacity 260ms var(--ease-ornate),
        transform 320ms var(--ease-ornate);
    }

    .nav-root[data-nav-open] .nav-link,
    .nav-root[data-nav-open] .nav-resume--panel {
      opacity: 1;
      transform: translateX(0);
    }

    /* Stagger — 6 nav items + resume button. Base 120ms + 45ms each. */
    .nav-root[data-nav-open] .nav-link:nth-child(1) { transition-delay: 120ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(2) { transition-delay: 165ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(3) { transition-delay: 210ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(4) { transition-delay: 255ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(5) { transition-delay: 300ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(6) { transition-delay: 345ms; }
    .nav-root[data-nav-open] .nav-resume--panel { transition-delay: 400ms; }
  }

  /* Desktop: strip the panel treatment; it's a plain inline flex row. */
  @media (min-width: 900px) {
    .nav-links {
      position: static;
      visibility: visible;
      opacity: 1;
      transform: none;
      pointer-events: auto;
      padding: 0;
      background: none;
      border-bottom: none;
      box-shadow: none;
      max-height: none;
      overflow: visible;
      transition: none;
    }

    .nav-link,
    .nav-resume--panel {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 899px) and (prefers-reduced-motion: reduce) {
    .nav-links,
    .nav-links::before,
    .nav-link,
    .nav-resume--panel {
      transition: opacity 80ms linear !important;
      transform: none !important;
    }
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-500);
    border-radius: 2px;
    transition: color var(--dur-fast) var(--ease-standard);
  }

  @media (max-width: 899px) {
    .nav-link {
      padding: 0.85rem 0.5rem;
      font-size: 0.95rem;
      border-bottom: 1px solid rgba(240, 185, 11, 0.06);
    }

    .nav-link:last-of-type {
      border-bottom: none;
    }
  }

  .nav-link:hover {
    color: var(--gold-200);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 0.1rem;
    width: 0;
    height: 1px;
    background: var(--gold-300);
    transform: translateX(-50%);
    transition: width var(--dur-base) var(--ease-ornate);
  }

  @media (max-width: 899px) {
    .nav-link::after {
      display: none;
    }
  }

  .nav-link:hover::after,
  .nav-link.is-active::after {
    width: 60%;
  }

  .nav-link.is-active {
    color: var(--gold-200);
  }

  .nav-glyph {
    font-size: 0.95rem;
    color: var(--gold-400);
    opacity: 0.8;
  }

  /* -------- RESUME BUTTON -------- */
  .nav-resume {
    font-size: 0.8rem;
    padding: 0.55rem 1.1rem;
  }

  /* Desktop: show the inline resume button next to the nav. */
  .nav-resume--desktop {
    display: none;
  }

  @media (min-width: 900px) {
    .nav-resume--desktop {
      display: inline-flex;
    }
    .nav-resume--panel {
      display: none;
    }
  }

  /* Mobile: resume button sits at the bottom of the open panel. */
  @media (max-width: 899px) {
    .nav-resume--panel {
      margin-top: 0.75rem;
      justify-content: center;
      width: 100%;
    }
  }
</style>
