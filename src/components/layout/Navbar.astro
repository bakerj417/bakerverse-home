---
import { nav, site } from '@/data/site';
import { listThemes } from '@/lib/theme/registry';
const { pathname } = Astro.url;
const themes = listThemes();
---

<!--
  aria-live region: screen readers announce the theme name when it changes.
  Positioned off-screen so it is invisible but always in the DOM.
-->
<div
  id="theme-live"
  role="status"
  aria-live="polite"
  aria-atomic="true"
  class="sr-only"
></div>

<header class="nav-root" data-nav-root>
  <a href="/" class="nav-brand" aria-label="Joseph Baker — home">
    <span class="nav-monogram" aria-hidden="true">JB</span>
    <span class="nav-brand-text">
      <span class="nav-brand-name">{site.name}</span>
      <span class="nav-brand-tagline">Bakerverse · Est. 2026</span>
    </span>
  </a>

  <button
    type="button"
    class="nav-toggle"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="primary-nav"
    data-nav-toggle
  >
    <span class="nav-toggle-bar" aria-hidden="true"></span>
    <span class="nav-toggle-bar" aria-hidden="true"></span>
    <span class="nav-toggle-bar" aria-hidden="true"></span>
  </button>

  <nav
    id="primary-nav"
    class="nav-links"
    aria-label="Primary"
    data-nav-panel
  >
    {nav.map((item) => {
      const isActive =
        item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);
      return (
        <a
          href={item.href}
          class:list={['nav-link', isActive && 'is-active']}
          aria-current={isActive ? 'page' : undefined}
        >
          <span class="nav-glyph" aria-hidden="true">{item.glyph}</span>
          <span class="nav-label">{item.label}</span>
        </a>
      );
    })}

    <!-- Mobile-only Theme section in the nav panel -->
    <div class="theme-panel-section" aria-label="Theme" role="group">
      <span class="theme-panel-label" aria-hidden="true">⬡ Theme</span>
      <div class="theme-panel-grid" role="listbox" aria-label="Choose theme" data-theme-grid="mobile">
        {themes.map((t) => (
          <button
            type="button"
            role="option"
            class="theme-swatch-btn"
            data-theme-id={t.meta.id}
            aria-label={`${t.meta.name} — ${t.meta.mood}`}
            aria-selected="false"
            data-theme-btn
          >
            <img
              src={`/themes/${t.meta.id}.svg`}
              alt=""
              aria-hidden="true"
              class="theme-swatch-img"
              width="80"
              height="45"
              loading="lazy"
            />
            <span class="theme-swatch-name">{t.meta.name}</span>
          </button>
        ))}
      </div>
    </div>

    <a
      href={site.resumeUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-gold nav-resume nav-resume--panel"
    >
      <span>Resume</span>
      <span aria-hidden="true">⤓</span>
    </a>
  </nav>

  <!-- Desktop theme picker button + popover -->
  <div class="theme-picker" data-theme-picker>
    <button
      type="button"
      class="theme-picker-btn"
      aria-label="Change theme"
      aria-haspopup="listbox"
      aria-expanded="false"
      aria-controls="theme-picker-popover"
      data-theme-picker-toggle
    >
      <span class="theme-picker-icon" aria-hidden="true">⬡</span>
    </button>

    <div
      id="theme-picker-popover"
      class="theme-picker-popover tooltip-card"
      role="listbox"
      aria-label="Choose theme"
      hidden
      data-theme-picker-popover
    >
      <p class="theme-picker-heading">Theme</p>
      <div class="theme-picker-grid" data-theme-grid="desktop">
        {themes.map((t) => (
          <button
            type="button"
            role="option"
            class="theme-swatch-btn"
            data-theme-id={t.meta.id}
            aria-label={`${t.meta.name} — ${t.meta.mood}`}
            aria-selected="false"
            data-theme-btn
          >
            <img
              src={`/themes/${t.meta.id}.svg`}
              alt=""
              aria-hidden="true"
              class="theme-swatch-img"
              width="96"
              height="54"
              loading="lazy"
            />
            <span class="theme-swatch-name">{t.meta.name}</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <a
    href={site.resumeUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="btn-gold nav-resume nav-resume--desktop"
  >
    <span>Resume</span>
    <span aria-hidden="true">⤓</span>
  </a>
</header>

<script>
  // -------------------------------------------------------------------------
  // Theme switcher — vanilla, framework-free
  // Re-bound on astro:page-load like the nav hamburger.
  // -------------------------------------------------------------------------

  import { getThemeId, setThemeId } from '@/lib/theme/store';
  import { applyTheme } from '@/lib/theme/apply';
  import { listThemes } from '@/lib/theme/registry';

  const THEME_IDS = listThemes().map((t) => t.meta.id);

  // ---- Sync all swatch buttons to the active theme ----
  function syncSwatches(activeId: string): void {
    document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]').forEach((btn) => {
      const isActive = btn.dataset.themeId === activeId;
      btn.setAttribute('aria-selected', String(isActive));
      btn.classList.toggle('is-active', isActive);
    });
  }

  // ---- Announce theme change to screen readers ----
  function announceTheme(id: string): void {
    const theme = listThemes().find((t) => t.meta.id === id);
    if (!theme) return;
    const live = document.getElementById('theme-live');
    if (!live) return;
    live.textContent = ''; // clear first so same-name re-announces
    requestAnimationFrame(() => {
      live.textContent = `Theme changed to ${theme.meta.name}: ${theme.meta.mood}`;
    });
  }

  // ---- Apply + announce a theme ----
  function selectTheme(id: string): void {
    setThemeId(id);
    applyTheme(id);
    syncSwatches(id);
    announceTheme(id);
  }

  // ---- Desktop popover open/close ----
  function openPicker(): void {
    const picker = document.querySelector<HTMLElement>('[data-theme-picker]');
    const toggle = document.querySelector<HTMLButtonElement>('[data-theme-picker-toggle]');
    const popover = document.querySelector<HTMLElement>('[data-theme-picker-popover]');
    if (!picker || !toggle || !popover) return;
    popover.removeAttribute('hidden');
    toggle.setAttribute('aria-expanded', 'true');
    // Focus first swatch in the popover for keyboard users
    const first = popover.querySelector<HTMLButtonElement>('[data-theme-btn]');
    first?.focus();
  }

  function closePicker(returnFocus = true): void {
    const toggle = document.querySelector<HTMLButtonElement>('[data-theme-picker-toggle]');
    const popover = document.querySelector<HTMLElement>('[data-theme-picker-popover]');
    if (!toggle || !popover) return;
    popover.setAttribute('hidden', '');
    toggle.setAttribute('aria-expanded', 'false');
    if (returnFocus) toggle.focus();
  }

  function pickerIsOpen(): boolean {
    const popover = document.querySelector<HTMLElement>('[data-theme-picker-popover]');
    return popover !== null && !popover.hasAttribute('hidden');
  }

  // ---- Keyboard navigation within a swatch grid ----
  function gridKeydown(e: KeyboardEvent, container: HTMLElement): void {
    const btns = Array.from(container.querySelectorAll<HTMLButtonElement>('[data-theme-btn]'));
    const idx = btns.indexOf(document.activeElement as HTMLButtonElement);
    if (idx === -1) return;

    let next = idx;
    switch (e.key) {
      case 'ArrowRight':
      case 'ArrowDown':
        e.preventDefault();
        next = (idx + 1) % btns.length;
        break;
      case 'ArrowLeft':
      case 'ArrowUp':
        e.preventDefault();
        next = (idx - 1 + btns.length) % btns.length;
        break;
      case 'Home':
        e.preventDefault();
        next = 0;
        break;
      case 'End':
        e.preventDefault();
        next = btns.length - 1;
        break;
      default:
        return;
    }
    btns[next]?.focus();
  }

  // ---- Wire everything up (called on each astro:page-load) ----
  function initThemeSwitcher(): void {
    // Sync swatches to current theme
    syncSwatches(getThemeId());

    // --- Desktop picker toggle ---
    const pickerToggle = document.querySelector<HTMLButtonElement>('[data-theme-picker-toggle]');
    if (pickerToggle && !(pickerToggle as HTMLButtonElement & { _pickerBound?: boolean })._pickerBound) {
      (pickerToggle as HTMLButtonElement & { _pickerBound?: boolean })._pickerBound = true;

      pickerToggle.addEventListener('click', () => {
        if (pickerIsOpen()) closePicker();
        else openPicker();
      });
    }

    // --- Swatch buttons (desktop + mobile, both grids) ---
    document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]').forEach((btn) => {
      if ((btn as HTMLButtonElement & { _swatchBound?: boolean })._swatchBound) return;
      (btn as HTMLButtonElement & { _swatchBound?: boolean })._swatchBound = true;

      btn.addEventListener('click', () => {
        const id = btn.dataset.themeId;
        if (id) selectTheme(id);
        // Close desktop popover after selection
        if (pickerIsOpen()) closePicker(false);
      });
    });

    // --- Keyboard nav inside desktop popover grid ---
    const desktopGrid = document.querySelector<HTMLElement>('[data-theme-grid="desktop"]');
    if (desktopGrid && !(desktopGrid as HTMLElement & { _kbBound?: boolean })._kbBound) {
      (desktopGrid as HTMLElement & { _kbBound?: boolean })._kbBound = true;
      desktopGrid.addEventListener('keydown', (e) => gridKeydown(e, desktopGrid));
    }

    // --- Keyboard nav inside mobile panel grid ---
    const mobileGrid = document.querySelector<HTMLElement>('[data-theme-grid="mobile"]');
    if (mobileGrid && !(mobileGrid as HTMLElement & { _kbBound?: boolean })._kbBound) {
      (mobileGrid as HTMLElement & { _kbBound?: boolean })._kbBound = true;
      mobileGrid.addEventListener('keydown', (e) => gridKeydown(e, mobileGrid));
    }
  }

  document.addEventListener('astro:page-load', initThemeSwitcher);

  // --- Close desktop picker on outside click ---
  document.addEventListener('click', (e: MouseEvent) => {
    if (!pickerIsOpen()) return;
    const picker = document.querySelector<HTMLElement>('[data-theme-picker]');
    if (picker && !picker.contains(e.target as Node)) closePicker(false);
  });

  // --- Close desktop picker on Escape ---
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && pickerIsOpen()) closePicker();
  });

  // -------------------------------------------------------------------------
  // Original nav hamburger logic (unchanged from before)
  // -------------------------------------------------------------------------

  function closeNav() {
    const root = document.querySelector<HTMLElement>('[data-nav-root]');
    const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
    if (!root || !toggle) return;
    root.removeAttribute('data-nav-open');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open menu');
  }

  function openNav() {
    const root = document.querySelector<HTMLElement>('[data-nav-root]');
    const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
    if (!root || !toggle) return;
    if (root.hasAttribute('data-nav-open')) return;
    root.setAttribute('data-nav-open', '');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close menu');
  }

  function initNav() {
    const root = document.querySelector<HTMLElement>('[data-nav-root]');
    const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
    const panel = document.querySelector<HTMLElement>('[data-nav-panel]');
    if (!root || !toggle || !panel) return;

    if (toggle.dataset.navBound === '1') return;
    toggle.dataset.navBound = '1';

    toggle.addEventListener('click', () => {
      if (root.hasAttribute('data-nav-open')) closeNav();
      else openNav();
    });

    panel.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
      link.addEventListener('click', closeNav);
    });
  }

  document.addEventListener('astro:page-load', initNav);

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const root = document.querySelector<HTMLElement>('[data-nav-root]');
    if (root?.hasAttribute('data-nav-open')) closeNav();
  });

  const desktopMq = window.matchMedia('(min-width: 900px)');
  desktopMq.addEventListener('change', (e) => {
    if (e.matches) {
      closeNav();
      const root = document.querySelector<HTMLElement>('[data-nav-root]');
      root?.removeAttribute('data-nav-hidden');
    }
  });

  const HIDE_AFTER = 80;
  const SHOW_DELTA = 2;
  const HIDE_DELTA = 10;
  let lastY = window.scrollY;
  let ticking = false;

  function showNav() {
    const root = document.querySelector<HTMLElement>('[data-nav-root]');
    root?.removeAttribute('data-nav-hidden');
  }

  function onScroll() {
    if (ticking) return;
    ticking = true;
    window.requestAnimationFrame(() => {
      ticking = false;
      if (desktopMq.matches) return;
      const root = document.querySelector<HTMLElement>('[data-nav-root]');
      if (!root) return;
      if (root.hasAttribute('data-nav-open')) {
        root.removeAttribute('data-nav-hidden');
        lastY = window.scrollY;
        return;
      }
      const y = window.scrollY;
      const dy = y - lastY;
      if (y < HIDE_AFTER) {
        root.removeAttribute('data-nav-hidden');
        lastY = y;
        return;
      }
      if (dy <= -SHOW_DELTA) {
        root.removeAttribute('data-nav-hidden');
        lastY = y;
      } else if (dy >= HIDE_DELTA) {
        root.setAttribute('data-nav-hidden', '');
        lastY = y;
      }
    });
  }

  window.addEventListener('scroll', onScroll, { passive: true });

  let touchStartY: number | null = null;
  window.addEventListener('touchstart', (e) => {
    if (desktopMq.matches) return;
    touchStartY = e.touches[0]?.clientY ?? null;
  }, { passive: true });
  window.addEventListener('touchmove', (e) => {
    if (desktopMq.matches) return;
    if (touchStartY == null) return;
    const y = e.touches[0]?.clientY;
    if (y == null) return;
    if (y - touchStartY > 8) showNav();
  }, { passive: true });
  window.addEventListener('touchend', () => {
    touchStartY = null;
  }, { passive: true });

  document.addEventListener('astro:page-load', () => {
    lastY = window.scrollY;
    showNav();
  });
</script>

<style>
  /* =====================================================================
     SR-ONLY utility (keeps aria-live region accessible but invisible)
  ====================================================================== */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* =====================================================================
     NAV ROOT
  ====================================================================== */
  .nav-root {
    position: sticky;
    top: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1.1rem;
    background: linear-gradient(180deg, rgba(7, 6, 10, 0.92) 0%, rgba(7, 6, 10, 0.7) 80%, transparent 100%);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(240, 185, 11, 0.08);
    transition: transform 280ms var(--ease-ornate);
    will-change: transform;
  }

  @media (max-width: 899px) {
    .nav-root[data-nav-hidden] {
      transform: translateY(-105%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-root {
      transition: none;
    }
  }

  @media (min-width: 900px) {
    .nav-root {
      gap: 2rem;
      padding: 1rem 2rem;
    }
  }

  /* =====================================================================
     BRAND
  ====================================================================== */
  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink-100);
    min-width: 0;
  }

  .nav-brand:hover {
    color: var(--ink-100);
  }

  .nav-monogram {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--gold-200);
    background:
      radial-gradient(circle at 30% 30%, rgba(240, 185, 11, 0.2), transparent 70%),
      linear-gradient(180deg, rgba(29, 26, 38, 0.9), rgba(13, 12, 20, 0.95));
    border: 1px solid var(--gold-500);
    border-radius: 2px;
    box-shadow: var(--shadow-gold-glow);
  }

  .nav-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    min-width: 0;
  }

  .nav-brand-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink-100);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .nav-brand-tagline {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--ink-500);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* =====================================================================
     HAMBURGER TOGGLE (mobile only)
  ====================================================================== */
  .nav-toggle {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    background: transparent;
    border: 1px solid rgba(240, 185, 11, 0.25);
    border-radius: 2px;
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-standard);
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0;
  }

  .nav-toggle:hover {
    border-color: var(--gold-400);
  }

  .nav-toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--gold-300);
    border-radius: 1px;
    transition:
      transform var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard);
  }

  @media (min-width: 900px) {
    .nav-toggle {
      display: none;
    }
  }

  .nav-root[data-nav-open] .nav-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-root[data-nav-open] .nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .nav-root[data-nav-open] .nav-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* =====================================================================
     NAV LINKS PANEL
  ====================================================================== */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  @media (max-width: 899px) {
    .nav-links {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      padding: 1rem 1rem 1.25rem;
      background: linear-gradient(
        180deg,
        rgba(7, 6, 10, 0.98) 0%,
        rgba(13, 12, 20, 0.98) 100%
      );
      border-bottom: 1px solid rgba(240, 185, 11, 0.15);
      box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.85);
      max-height: calc(100vh - 60px);
      overflow-y: auto;
      visibility: hidden;
      opacity: 0;
      transform: scaleY(0.92) translateY(-6px);
      transform-origin: top center;
      pointer-events: none;
      transition:
        opacity 200ms var(--ease-ornate),
        transform 240ms var(--ease-ornate),
        visibility 0s linear 260ms;
    }

    .nav-root[data-nav-open] .nav-links {
      visibility: visible;
      opacity: 1;
      transform: scaleY(1) translateY(0);
      pointer-events: auto;
      transition:
        opacity 180ms var(--ease-ornate),
        transform 380ms cubic-bezier(0.16, 1, 0.3, 1),
        visibility 0s linear 0s;
    }

    .nav-links::before {
      content: "";
      position: absolute;
      top: 0;
      left: 5%;
      right: 5%;
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(240, 185, 11, 0.55) 18%,
        rgba(255, 237, 176, 0.95) 50%,
        rgba(240, 185, 11, 0.55) 82%,
        transparent 100%
      );
      box-shadow: 0 0 14px 2px rgba(240, 185, 11, 0.4);
      transform: scaleX(0);
      transform-origin: center;
      transition: transform 440ms cubic-bezier(0.16, 1, 0.3, 1) 40ms;
      pointer-events: none;
    }

    .nav-root[data-nav-open] .nav-links::before {
      transform: scaleX(1);
    }

    .nav-link,
    .nav-resume--panel {
      opacity: 0;
      transform: translateX(-10px);
      transition:
        opacity 260ms var(--ease-ornate),
        transform 320ms var(--ease-ornate);
    }

    .nav-root[data-nav-open] .nav-link,
    .nav-root[data-nav-open] .nav-resume--panel {
      opacity: 1;
      transform: translateX(0);
    }

    .nav-root[data-nav-open] .nav-link:nth-child(1) { transition-delay: 120ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(2) { transition-delay: 165ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(3) { transition-delay: 210ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(4) { transition-delay: 255ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(5) { transition-delay: 300ms; }
    .nav-root[data-nav-open] .nav-link:nth-child(6) { transition-delay: 345ms; }
    .nav-root[data-nav-open] .nav-resume--panel    { transition-delay: 400ms; }
  }

  @media (min-width: 900px) {
    .nav-links {
      position: static;
      visibility: visible;
      opacity: 1;
      transform: none;
      pointer-events: auto;
      padding: 0;
      background: none;
      border-bottom: none;
      box-shadow: none;
      max-height: none;
      overflow: visible;
      transition: none;
    }

    .nav-link,
    .nav-resume--panel {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 899px) and (prefers-reduced-motion: reduce) {
    .nav-links,
    .nav-links::before,
    .nav-link,
    .nav-resume--panel {
      transition: opacity 80ms linear !important;
      transform: none !important;
    }
  }

  /* =====================================================================
     NAV LINKS
  ====================================================================== */
  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-500);
    border-radius: 2px;
    transition: color var(--dur-fast) var(--ease-standard);
  }

  @media (max-width: 899px) {
    .nav-link {
      padding: 0.85rem 0.5rem;
      font-size: 0.95rem;
      border-bottom: 1px solid rgba(240, 185, 11, 0.06);
    }

    .nav-link:last-of-type {
      border-bottom: none;
    }
  }

  .nav-link:hover {
    color: var(--gold-200);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 0.1rem;
