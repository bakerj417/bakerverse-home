# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values for local dev.
# For production, paste the same keys into
# Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# Gmail SMTP — Google Workspace account that sends contact form mail.
# Generate an App Password at myaccount.google.com/apppasswords
# (requires 2FA enabled on the GWS account).
GMAIL_USER="hello@example.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Where the contact form delivers mail.
CONTACT_TO_EMAIL="you@example.com"

# Cloudflare Turnstile — bot protection for the contact form.
# Get site + secret keys at https://dash.cloudflare.com → Turnstile.
# PUBLIC_ prefix is required so the browser bundle can read the sitekey.
PUBLIC_TURNSTILE_SITE_KEY="0xXXXXXXXXXXXXXXXXXXXXXX"
TURNSTILE_SECRET_KEY="0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Sentry — error monitoring.
# DSN is the project ingest URL from sentry.io → Project → Settings → Client Keys.
# Auth token is a Sentry internal integration token with project:read scope.
# Generate at sentry.io → Settings → Auth Tokens.
# Both are production-only; Sentry is disabled on localhost (no env vars present).
SENTRY_DSN="https://xxxx@oXXXX.ingest.us.sentry.io/XXXX"
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxxxxxxxxxx"
